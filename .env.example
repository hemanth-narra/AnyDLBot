# ── Required ───────────────────────────────────────────────────────────────
# Bot token from @BotFather on Telegram
TG_BOT_TOKEN=

# From https://my.telegram.org → App API
APP_ID=
API_HASH=

# ── Optional ───────────────────────────────────────────────────────────────
# Space-separated Telegram user IDs that are permanently banned.
BANNED_USERS=

# Proxy URL for geo-restricted sites (e.g. socks5://127.0.0.1:1080)
HTTP_PROXY=

# Download chunk size in bytes (default: 128)
CHUNK_SIZE=128

# URL to a fallback thumbnail image used for videos with no thumbnail
DEF_THUMB_NAIL_VID_S=
